\f0\fs24 \cf0 <!DOCTYPE html>\
<html lang="zh">\
<head>\
    <meta charset="UTF-8">\
    <meta name="viewport" content="width=device-width, initial-scale=1.0">\
    <title>\uc0\u20320 \u26159 \u21738 \u20301 \u21746 \u23398 \u23478 \u65311 - \u28789 \u39746 \u27979 \u35797 </title>\
    <script src="https://cdn.tailwindcss.com"></script>\
    <style>\
        @import url('https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;700&display=swap');\
        body \{ font-family: 'Noto Serif SC', serif; background-color: #f4f1ea; \}\
    </style>\
</head>\
<body class="flex flex-col items-center justify-center min-h-screen p-4 text-gray-800">\
\
    <div id="quiz-container" class="max-w-2xl w-full bg-white p-8 rounded-lg shadow-xl border border-stone-200">\
        <!-- \uc0\u24320 \u22987 \u30028 \u38754  -->\
        <div id="start-screen" class="text-center">\
            <h1 class="text-3xl font-bold mb-4 text-stone-700">\uc0\u25506 \u32034 \u20320 \u30340 \u28789 \u39746 \u24213 \u33394 </h1>\
            <p class="mb-6 text-stone-500">\uc0\u22914 \u26524 \u36328 \u36234 \u26102 \u31354 \u65292 \u20320 \u20250 \u26159 \u21738 \u19968 \u20301 \u21746 \u23398 \u24040 \u21280 \u65311 </p>\
            <button onclick="startQuiz()" class="bg-stone-700 text-white px-8 py-3 rounded hover:bg-stone-800 transition">\uc0\u24320 \u21551 \u24605 \u24819 \u20043 \u26053 </button>\
        </div>\
\
        <!-- \uc0\u39064 \u30446 \u30028 \u38754  -->\
        <div id="question-screen" class="hidden">\
            <div class="mb-2 text-sm text-stone-400" id="progress">\uc0\u38382 \u39064  1 / 3</div>\
            <h2 id="question-text" class="text-xl font-bold mb-6">\uc0\u22914 \u26524 \u20320 \u21457 \u29616 \u19968 \u22788 \u32477 \u32654 \u30340 \u39118 \u26223 \u65292 \u20320 \u20250 \u65311 </h2>\
            <div id="options" class="space-y-4">\
                <!-- \uc0\u36873 \u39033 \u20250 \u21160 \u24577 \u29983 \u25104  -->\
            </div>\
        </div>\
\
        <!-- \uc0\u32467 \u26524 \u30028 \u38754  -->\
        <div id="result-screen" class="hidden text-center">\
            <h2 class="text-2xl mb-2">\uc0\u20320 \u30340 \u21746 \u23398 \u20154 \u26684 \u26159 \u65306 </h2>\
            <div id="philosopher-name" class="text-5xl font-bold text-stone-800 mb-4">\uc0\u23612 \u37319 </div>\
            <p id="philosopher-desc" class="italic text-stone-600 mb-6 leading-relaxed"></p>\
            <button onclick="location.reload()" class="text-stone-500 underline">\uc0\u37325 \u26032 \u27979 \u35797 </button>\
        </div>\
    </div>\
\
    <script>\
        const questions = [\
            \{\
                text: "\uc0\u38754 \u23545 \u26410 \u30693 \u30340 \u22256 \u38590 \u65292 \u20320 \u30340 \u31532 \u19968 \u21453 \u24212 \u26159 \u65311 ",\
                options: [\
                    \{ text: "\uc0\u36814 \u38590 \u32780 \u19978 \u65292 \u29992 \u24847 \u24535 \u21147 \u24449 \u26381 \u23427 ", scores: \{ nietzsche: 3, kant: 1 \} \},\
                    \{ text: "\uc0\u20998 \u26512 \u35268 \u24459 \u65292 \u23547 \u25214 \u36923 \u36753 \u19978 \u30340 \u26368 \u20248 \u35299 ", scores: \{ kant: 3, socrates: 2 \} \},\
                    \{ text: "\uc0\u39034 \u20854 \u33258 \u28982 \u65292 \u30475 \u30475 \u20107 \u24577 \u22914 \u20309 \u28436 \u21464 ", scores: \{ laozi: 3, epicurus: 1 \} \}\
                ]\
            \},\
            \{\
                text: "\uc0\u20320 \u35748 \u20026 \u20154 \u29983 \u30340 \u32456 \u26497 \u24847 \u20041 \u26159 \u20160 \u20040 \u65311 ",\
                options: [\
                    \{ text: "\uc0\u21019 \u36896 \u36229 \u36234 \u33258 \u25105 \u30340 \u20215 \u20540 ", scores: \{ nietzsche: 3 \} \},\
                    \{ text: "\uc0\u23653 \u34892 \u24212 \u23613 \u30340 \u36947 \u24503 \u36131 \u20219 ", scores: \{ kant: 3 \} \},\
                    \{ text: "\uc0\u20139 \u21463 \u24403 \u19979 \u30340 \u24179 \u38745 \u19982 \u24555 \u20048 ", scores: \{ epicurus: 3, laozi: 1 \} \}\
                ]\
            \}\
        ];\
\
        const results = \{\
            nietzsche: \{ name: "\uc0\u23612 \u37319 ", desc: "\u20320 \u26159 \u36229 \u20154 \u21746 \u23398 \u30340 \u36341 \u34892 \u32773 \u12290 \u20320 \u19981 \u30031 \u30171 \u33510 \u65292 \u34065 \u35270 \u24179 \u24248 \u65292 \u36890 \u36807 \u19981 \u26029 \u30340 \u33258 \u25105 \u36229 \u36234 \u26469 \u21019 \u36896 \u29983 \u21629 \u30340 \u24847 \u20041 \u12290 " \},\
            kant: \{ name: "\uc0\u24247 \u24503 ", desc: "\u20320 \u26159 \u29702 \u24615 \u30340 \u21270 \u36523 \u12290 \u20320 \u28145 \u20449 \u22836 \u39030 \u30340 \u26143 \u31354 \u21644 \u20869 \u24515 \u30340 \u36947 \u24503 \u24459 \u65292 \u29983 \u27963 \u39640 \u24230 \u33258 \u24459 \u19988 \u20805 \u28385 \u36923 \u36753 \u12290 " \},\
            laozi: \{ name: "\uc0\u32769 \u23376 ", desc: "\u20320 \u25317 \u26377 \u26497 \u39640 \u30340 \u26234 \u24935 \u19982 \u36890 \u36879 \u12290 \u20320 \u28145 \u35865 \'91\u26080 \u20026 \u32780 \u27835 \'92\u65292 \u22312 \u19975 \u29289 \u21464 \u36801 \u20013 \u23547 \u25214 \u37027 \u20221 \u23425 \u38745 \u19982 \u24179 \u34913 \u12290 " \},\
            epicurus: \{ name: "\uc0\u20234 \u22721 \u40480 \u40065 ", desc: "\u20320 \u26159 \u19968 \u20301 \u28201 \u21644 \u30340 \u26234 \u32773 \u12290 \u20320 \u36861 \u27714 \u30340 \u26159 \u25670 \u33073 \u24656 \u24807 \u19982 \u30171 \u33510 \u65292 \u20139 \u21463 \u21451 \u35850 \u19982 \u31616 \u21333 \u30340 \u29983 \u27963 \u24555 \u20048 \u12290 " \}\
        \};\
\
        let currentQuestion = 0;\
        let userScores = \{ nietzsche: 0, kant: 0, laozi: 0, epicurus: 0 \};\
\
        function startQuiz() \{\
            document.getElementById('start-screen').classList.add('hidden');\
            document.getElementById('question-screen').classList.remove('hidden');\
            showQuestion();\
        \}\
\
        function showQuestion() \{\
            const q = questions[currentQuestion];\
            document.getElementById('question-text').innerText = q.text;\
            document.getElementById('progress').innerText = `\uc0\u38382 \u39064  $\{currentQuestion + 1\} / $\{questions.length\}`;\
            const optionsDiv = document.getElementById('options');\
            optionsDiv.innerHTML = '';\
            \
            q.options.forEach(opt => \{\
                const btn = document.createElement('button');\
                btn.className = "w-full text-left p-4 border border-stone-200 rounded hover:bg-stone-50 transition";\
                btn.innerText = opt.text;\
                btn.onclick = () => selectOption(opt.scores);\
                optionsDiv.appendChild(btn);\
            \});\
        \}\
\
        function selectOption(scores) \{\
            for (let philo in scores) \{\
                userScores[philo] += scores[philo];\
            \}\
            currentQuestion++;\
            if (currentQuestion < questions.length) \{\
                showQuestion();\
            \} else \{\
                showResult();\
            \}\
        \}\
\
        function showResult() \{\
            document.getElementById('question-screen').classList.add('hidden');\
            document.getElementById('result-screen').classList.remove('hidden');\
            \
            // \uc0\u25214 \u21040 \u24471 \u20998 \u26368 \u39640 \u30340 \u21746 \u23398 \u23478 \
            const winner = Object.keys(userScores).reduce((a, b) => userScores[a] > userScores[b] ? a : b);\
            \
            document.getElementById('philosopher-name').innerText = results[winner].name;\
            document.getElementById('philosopher-desc').innerText = results[winner].desc;\
        \}\
    </script>\
</body>\
</html>}